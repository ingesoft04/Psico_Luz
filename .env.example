# ─── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
HTTP_PORT=8180
APP_NAME="Psicóloga Luz Adriana API"
APP_URL=http://localhost
FRONTEND_URL=http://localhost

# ─── Seguridad ────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro_2025
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=otro_secreto_para_refresh_token_2025
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=12

# ─── Cuentas operativas gestionadas ───────────────────────────
PSYCHOLOGIST_NAME="Luz Adriana"
PSYCHOLOGIST_LASTNAME="Psicóloga"
PSYCHOLOGIST_EMAIL=psicologa@tudominio.com
PSYCHOLOGIST_PASSWORD=cambia_esta_clave_psicologa
MAINTENANCE_NAME="Soporte"
MAINTENANCE_LASTNAME="Técnico"
MAINTENANCE_EMAIL=mantenimiento@tudominio.com
MAINTENANCE_PASSWORD=cambia_esta_clave_mantenimiento

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=psicologa_db
POSTGRES_USER=psicologa_user
POSTGRES_PASSWORD=cambia_esto_password_seguro_2025
DB_HOST=postgres
DB_PORT=5432
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2025
REDIS_TTL_DEFAULT=3600        # 1 hora en segundos
REDIS_TTL_SESSION=604800      # 7 días
REDIS_TTL_CACHE=1800          # 30 minutos

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password_gmail
EMAIL_FROM="Psicóloga Luz Adriana <noreply@psicologa.co>"

# ─── WhatsApp (Twilio o similar) ──────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Cloudinary (fotos/archivos) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ─── IA — Claude (Anthropic) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=2048

# ─── IA — Gemini (Google) ─────────────────────────────────────
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-1.5-pro

# ─── N8N ──────────────────────────────────────────────────────
N8N_HOST=localhost
N8N_USER=admin
N8N_PASSWORD=n8n_2025_seguro
N8N_WEBHOOK_SECRET=webhook_secret_n8n_2025

# ─── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@psicologa.co
PGADMIN_PASSWORD=pgadmin_2025

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutos
RATE_LIMIT_MAX=1000
RATE_LIMIT_AUTH_MAX=10
CLINICAL_SIGNING_SECRET=cambia_este_secreto_para_firmar_documentos_clinicos

# ─── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ─── Videoconsulta ─────────────────────────────────────────────
VIDEO_BASE_URL=https://meet.jit.si
