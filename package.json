{
  "name": "psicologa-luz-adriana-api",
  "version": "1.0.0",
  "description": "Backend API — Psicóloga Luz Adriana. PostgreSQL · Redis · N8N · Claude AI · Gemini",
  "main": "src/server.js",
  "scripts": {
    "start":     "node src/server.js",
    "dev":       "nodemon src/server.js",
    "lint":      "eslint src/",
    "test":      "jest --forceExit",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:tools": "docker-compose --profile tools up -d",
    "docker:auto":  "docker-compose --profile automation up -d",
    "docker:logs":  "docker-compose logs -f api",
    "db:seed":   "node scripts/seed.js"
  },
  "dependencies": {
    "express":               "^4.19.2",
    "pg":                    "^8.12.0",
    "ioredis":               "^5.4.1",
    "bcryptjs":              "^2.4.3",
    "jsonwebtoken":          "^9.0.2",
    "express-validator":     "^7.2.0",
    "express-rate-limit":    "^7.4.1",
    "rate-limit-redis":      "^4.2.0",
    "helmet":                "^7.1.0",
    "cors":                  "^2.8.5",
    "morgan":                "^1.10.0",
    "winston":               "^3.14.2",
    "nodemailer":            "^6.9.15",
    "multer":                "^1.4.5-lts.1",
    "cloudinary":            "^2.5.1",
    "twilio":                "^5.3.7",
    "node-cron":             "^3.0.3",
    "bull":                  "^4.16.3",
    "@anthropic-ai/sdk":     "^0.32.1",
    "@google/generative-ai": "^0.21.0",
    "dotenv":                "^16.4.5",
    "compression":           "^1.7.4",
    "express-async-errors":  "^3.1.1",
    "uuid":                  "^10.0.0",
    "dayjs":                 "^1.11.13",
    "zod":                   "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "jest":    "^29.7.0",
    "eslint":  "^9.13.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
